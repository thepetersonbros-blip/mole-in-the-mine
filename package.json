{
  "name": "mole-in-the-mine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.11 || >=22"
  },
  "scripts": {
    "dev": "concurrently -k -n srv,web \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && node scripts/build-server.mjs",
    "start": "node dist/server/index.cjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "concurrently": "^9.1.2",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^2.1.8"
  }
}
